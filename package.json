{
  "name": "opencode-mnemosyne-oss",
  "version": "0.2.8",
  "description": "OpenCode plugin for local persistent memory using official Mnemosyne - offline semantic search, no cloud required",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "ci": "tsc --noEmit && tsc"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "mnemosyne",
    "memory",
    "local",
    "offline",
    "semantic-search",
    "ai",
    "coding-agent"
  ],
  "author": "gandazgul",
  "contributors": [
    {
      "name": "Arkhi Muttaqina",
      "email": "arkhi07@gmail.com",
      "url": "https://github.com/ArkhiMuttaqina"
    },
    {
      "name": "gandazgul",
      "url": "https://github.com/gandazgul"
    }
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ArkhiMuttaqina/opencode-mnemosyne-oss.git"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.2.24"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "typescript": "^5.9.3"
  },
  "opencode": {
    "type": "plugin"
  },
  "files": [
    "dist"
  ]
}
